# Copy this file to .env and fill in real secrets.
OPENAI_API_KEY=
GROQ_API_KEY=

# API call logging for ontology/debug QA.
# Keep disabled by default because prompts and responses can contain sensitive content.
API_LOGGING_ENABLED=false
API_LOG_FILE=api_logs.jsonl
API_LOG_LEVEL=INFO
API_LOG_INCLUDE_PAIR=true
API_LOG_INCLUDE_CONTENT=false
API_LOG_INCLUDE_PARSED_RESPONSE=true
API_LOG_MAX_CONTENT_LENGTH=4000
API_LOG_EXCLUDE_EMBEDDING=true
